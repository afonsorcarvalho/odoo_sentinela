# Modo dos adapters de API: "mock" (dados simulados, sem backend) ou "real" (chama a API FastAPI)
VITE_API_MODE=mock

# URL base da API FastAPI (só é usada quando VITE_API_MODE=real)
VITE_API_BASE_URL=http://localhost:8001

# Nome da unidade/hospital exibido no topo do dashboard
VITE_UNIT_NAME=Hospital Demonstração

# Ativa o banner e os controles de simulação de não conformidade (uso em demos/apresentações)
VITE_DEMO_MODE=false
